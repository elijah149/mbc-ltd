# General
ENVIRONMENT=development

# Security - CHANGE THESE IN PRODUCTION
SECRET_KEY=super-secret-key-change-me-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
POSTGRES_SERVER=db
POSTGRES_USER=mbcu_user
POSTGRES_PASSWORD=mbcu_password
POSTGRES_DB=mbcu_erp
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mbcu-documents
MINIO_SECURE=false

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# First superuser (created by seed script)
FIRST_SUPERUSER_EMAIL=admin@mbcu.co.tz
FIRST_SUPERUSER_PASSWORD=ChangeMe123!
